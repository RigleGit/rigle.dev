 0 0 0-16-16zM16 160h64a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H64V40a8 8 0 0 0-8-8H32a8 8 0 0 0-7.14 4.42l-8 16A8 8 0 0 0 24 64h8v64H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8zm-3.91 160H80a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H41.32c3.29-10.29 48.34-18.68 48.34-56.44 0-29.06-25-39.56-44.47-39.56-21.36 0-33.8 10-40.46 18.75-4.37 5.59-3 10.84 2.8 15.37l8.58 6.88c5.61 4.56 11 2.47 16.12-2.44a13.44 13.44 0 0 1 9.46-3.84c3.33 0 9.28 1.56 9.28 8.75C51 248.19 0 257.31 0 304.59v4C0 316 5.08 320 12.09 320z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n\n      \u003cbutton \n        class=\"\n          wrap-code-button\n          tw-select-none \n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.is-wrap]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle code wrap\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M16 132h416c8.837 0 16-7.163 16-16V76c0-8.837-7.163-16-16-16H16C7.163 60 0 67.163 0 76v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n      \n      \u003cbutton \n        class=\"\n          copy-code-button\n          tw-select-none\n          tw-mx-2 \n          tw-hidden\n          group-[.is-open]:tw-block\n          hover:tw-text-fgColor-link \n          print:!tw-hidden\"\n        title=\"Copy code\"\u003e\n          \u003cspan class=\"copy-icon tw-block\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M433.941 65.941l-51.882-51.882A48 48 0 0 0 348.118 0H176c-26.51 0-48 21.49-48 48v48H48c-26.51 0-48 21.49-48 48v320c0 26.51 21.49 48 48 48h224c26.51 0 48-21.49 48-48v-48h80c26.51 0 48-21.49 48-48V99.882a48 48 0 0 0-14.059-33.941zM266 464H54a6 6 0 0 1-6-6V150a6 6 0 0 1 6-6h74v224c0 26.51 21.49 48 48 48h96v42a6 6 0 0 1-6 6zm128-96H182a6 6 0 0 1-6-6V54a6 6 0 0 1 6-6h106v88c0 13.255 10.745 24 24 24h88v202a6 6 0 0 1-6 6zm6-256h-64V48h9.632c1.591 0 3.117.632 4.243 1.757l48.368 48.368a6 6 0 0 1 1.757 4.243V112z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n          \u003cspan class=\"check-icon tw-hidden\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-2\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e5 6 11 12 13\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003ch2 id=\"common-mistakes\" class=\"headerLink\"\u003e\n    \u003ca href=\"#common-mistakes\" class=\"header-mark\" aria-label=\"Common mistakes\" title=\"Common mistakes\"\u003e\u003c/a\u003eCommon mistakes\u003c/h2\u003e\n\u003cul\u003e\n\u003cli\u003eForgetting to store the current value in \u003ccode\u003ekey\u003c/code\u003e before shifting.\u003c/li\u003e\n\u003cli\u003eWriting the final position incorrectly (\u003ccode\u003ea[j + 1] = key\u003c/code\u003e).\u003c/li\u003e\n\u003cli\u003eUsing \u003ccode\u003ej \u0026gt; 0\u003c/code\u003e instead of \u003ccode\u003ej \u0026gt;= 0\u003c/code\u003e.\u003c/li\u003e\n\u003cli\u003eIgnoring that runtime cost mainly comes from shifts.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"practical-use\" class=\"headerLink\"\u003e\n    \u003ca href=\"#practical-use\" class=\"header-mark\" aria-label=\"Practical use\" title=\"Practical use\"\u003e\u003c/a\u003ePractical use\u003c/h2\u003e\n\u003cp\u003eInsertion sort is useful when:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003earrays are small,\u003c/li\u003e\n\u003cli\u003einput is nearly sorted,\u003c/li\u003e\n\u003cli\u003eyou want a clear baseline before shell sort or merge sort.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eIt is also common in beginner assignments and junior interview screens.\u003c/p\u003e\n\u003ch2 id=\"recommended-next-exercise\" class=\"headerLink\"\u003e\n    \u003ca href=\"#recommended-next-exercise\" class=\"header-mark\" aria-label=\"Recommended next exercise\" title=\"Recommended next exercise\"\u003e\u003c/a\u003eRecommended next exercise\u003c/h2\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ca href=\"/en/ejercicios-c/shell-sort-en-c-ejercicio-resuelto/\" rel=\"\"\u003eShell sort in C: solved exercise step by step\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca href=\"/en/ejercicios-c/insercion-binaria-en-c-ejercicio-resuelto/\" rel=\"\"\u003eBinary insertion sort in C: solved exercise\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca href=\"/en/ejercicios-c/ordenacion-burbuja-en-c-ejercicio-resuelto/\" rel=\"\"\u003eBubble sort in C: solved exercise\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca href=\"/en/ejercicios-c/\" rel=\"\"\u003eAll C exercises\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"guided-practice-and-full-book\" class=\"headerLink\"\u003e\n    \u003ca href=\"#guided-practice-and-full-book\" class=\"header-mark\" aria-label=\"Guided practice and full book\" title=\"Guided practice and full book\"\u003e\u003c/a\u003eGuided practice and full book\u003c/h2\u003e\n\u003cp\u003eIf you want a complete path with progressive difficulty:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ca href=\"/en/c100/\" rel=\"\"\u003eProgramming in C in 100 Solved Exercises\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca href=\"https://www.amazon.com/dp/B0FZ4QHW8L\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eView on Amazon (included in Kindle Unlimited)\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"faq\" class=\"headerLink\"\u003e\n    \u003ca href=\"#faq\" class=\"header-mark\" aria-label=\"FAQ\" title=\"FAQ\"\u003e\u003c/a\u003eFAQ\u003c/h2\u003e\n\u003ch3 id=\"is-insertion-sort-in-c-good-for-beginners\" class=\"headerLink\"\u003e\n    \u003ca href=\"#is-insertion-sort-in-c-good-for-beginners\" class=\"header-mark\" aria-label=\"Is insertion sort in C good for beginners?\" title=\"Is insertion sort in C good for beginners?\"\u003e\u003c/a\u003eIs insertion sort in C good for beginners?\u003c/h3\u003e\n\u003cp\u003eYes. It is one of the best first algorithms to learn loops, comparisons, and shifts.\u003c/p\u003e\n\u003ch3 id=\"what-is-insertion-sort-complexity\" class=\"headerLink\"\u003e\n    \u003ca href=\"#what-is-insertion-sort-complexity\" class=\"header-mark\" aria-label=\"What is insertion sort complexity?\" title=\"What is insertion sort complexity?\"\u003e\u003c/a\u003eWhat is insertion sort complexity?\u003c/h3\u003e\n\u003cp\u003eWorst and average case: O(n²). Best case (nearly sorted input): O(n).\u003c/p\u003e\n\u003ch3 id=\"how-should-i-practice-insertion-sort-effectively\" class=\"headerLink\"\u003e\n    \u003ca href=\"#how-should-i-practice-insertion-sort-effectively\" class=\"header-mark\" aria-label=\"How should I practice insertion sort effectively?\" title=\"How should I practice insertion sort effectively?\"\u003e\u003c/a\u003eHow should I practice insertion sort effectively?\u003c/h3\u003e\n\u003cp\u003eTrace small arrays manually and count shifts per iteration. That makes performance behavior very clear.\u003c/p\u003e\n",
        "language": "en"
    },
    {
        "title" : "Shell sort in C: solved exercise step by step",
        "date_published" : "2026-03-01T00:00:00+01:00",
        "date_modified" : "2026-03-01T00:00:00+01:00",
        "id" : "https://rigle.dev/en/ejercicios-c/shell-sort-en-c-ejercicio-resuelto/",
        "url" : "https://rigle.dev/en/ejercicios-c/shell-sort-en-c-ejercicio-resuelto/",
        "summary": " Shell sort method in C If you are looking for a shell sort in C solved exercise, this post explains the full logic, not just the final code.\nShell sort improves insertion sort by using gaps. Instead of comparing only adjacent values, it compares values that are farther apart and progressively reduces the gap until it reaches 1. It is an in-place algorithm and often performs better than bubble sort or insertion sort on medium-sized arrays.\n",
        "content_html" : "\u003ch2 id=\"shell-sort-method-in-c\" class=\"headerLink\"\u003e\n    \u003ca href=\"#shell-sort-method-in-c\" class=\"header-mark\" aria-label=\"Shell sort method in C\" title=\"Shell sort method in C\"\u003e\u003c/a\u003eShell sort method in C\u003c/h2\u003e\n\u003cp\u003eIf you are looking for a \u003cstrong\u003eshell sort in C solved exercise\u003c/strong\u003e, this post explains the full logic, not just the final code.\u003c/p\u003e\n\u003cp\u003eShell sort improves insertion sort by using \u003cstrong\u003egaps\u003c/strong\u003e. Instead of comparing only adjacent values, it compares values that are farther apart and progressively reduces the gap until it reaches 1. It is an \u003cstrong\u003ein-place\u003c/strong\u003e algorithm and often performs better than bubble sort or insertion sort on medium-sized arrays.\u003c/p\u003e\n\u003ch2 id=\"problem-statement\" class=\"headerLink\"\u003e\n    \u003ca href=\"#problem-statement\" class=\"header-mark\" aria-label=\"Problem statement\" title=\"Problem statement\"\u003e\u003c/a\u003eProblem statement\u003c/h2\u003e\n\u003cp\u003eImplement shell sort to sort an integer array in ascending order.\u003c/p\u003e\n\u003ch2 id=\"c-solution\" class=\"headerLink\"\u003e\n    \u003ca href=\"#c-solution\" class=\"header-mark\" aria-label=\"C solution\" title=\"C solution\"\u003e\u003c/a\u003eC solution\u003c/h2\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ec\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zm0-160H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0